REACT_APP_APP_NAME=OralSync
REACT_APP_VERSION=1.0.0-beta

# 🌍 Environment
REACT_APP_ENV=development

# 🌐 API (fallback)
REACT_APP_API_URL=https://localhost:5001/

# 🔐 Features
REACT_APP_ENABLE_LOGGING=true
REACT_APP_ENABLE_DEBUG=true