{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/static/*",
      "/favicon.ico",
      "/OralSync.png",
      "/manifest.json",
      "/robots.txt",
      "/sitemap.xml"
    ]
  },
  "routes": [
    {
      "route": "/index.html",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "route": "/manifest.json",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "route": "/static/css/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/static/js/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/static/media/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/favicon.ico",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      }
    },
    {
      "route": "/OralSync.png",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      }
    },
    {
      "route": "/robots.txt",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/sitemap.xml",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    }
  ]
}
